<?xml version="1.0" encoding="UTF-8"?>
<!--
  Per-classifier natives bundle assembly — packs every FFmpeg
  shared library under
  `${project.basedir}/dependencies/ffmpeg/bin/${natives.classifier}/`
  into
  `modules/lib/dependencies/ffmpeg/bin/${natives.classifier}/`
  inside a JAR named
  `cobalt-${project.version}-natives-${natives.classifier}.jar`.

  The JAR-internal path matches the manifest's repo-relative path
  exactly so the loader's classpath probe (which uses the manifest
  path verbatim) finds binaries in the bundled JAR at the same
  coordinate it would download them from.

  Activated indirectly via the `natives` profile in
  modules/lib/pom.xml.
-->
<assembly xmlns="http://maven.apache.org/ASSEMBLY/2.2.0"
          xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
          xsi:schemaLocation="http://maven.apache.org/ASSEMBLY/2.2.0 http://maven.apache.org/xsd/assembly-2.2.0.xsd">
    <id>natives-${natives.classifier}</id>
    <formats>
        <format>jar</format>
    </formats>
    <includeBaseDirectory>false</includeBaseDirectory>
    <fileSets>
        <!--
            Single fileset per FFmpeg drop — the build-ffmpeg.sh
            script produces six shared libraries
            (libavformat / libavcodec / libavdevice / libavutil /
            libswscale / libswresample) into one
            `dependencies/ffmpeg/bin/<classifier>/` directory and we
            ship them all together. Missing files are silently
            skipped, so a partial cut (e.g. only Linux) still
            produces a usable JAR for that classifier.
        -->
        <fileSet>
            <directory>${project.basedir}/dependencies/ffmpeg/bin/${natives.classifier}</directory>
            <outputDirectory>modules/lib/dependencies/ffmpeg/bin/${natives.classifier}</outputDirectory>
            <includes>
                <include>*.so</include>
                <include>*.so.*</include>
                <include>*.dylib</include>
                <include>*.dll</include>
            </includes>
        </fileSet>
    </fileSets>
</assembly>
