    <groupId>com.github.auties00</groupId>
    <artifactId>cobalt</artifactId>
    <version>0.1.0</version>
    <packaging>pom</packaging>
    <name>${project.groupId}:${project.artifactId}</name>
    <description>Standalone fully-featured WhatsApp Web API for Java and Kotlin</description>
    <url>https://github.com/Auties00/Cobalt</url>

    <modules>
        <module>modules/wam-core</module>
        <module>modules/source-meta</module>
        <module>modules/model</module>
        <module>modules/lib</module>
    </modules>

    <developers>
        <developer>
            <name>Alessandro Autiero</name>
            <email>alautiero@gmail.com</email>
        </developer>
    </developers>

    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://www.opensource.org/licenses/mit-license.php</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <scm>
        <url>https://github.com/Auties00/Cobalt/tree/master</url>
        <connection>scm:git:https://github.com/Auties00/Cobalt.git</connection>
        <developerConnection>scm:ssh:https://github.com/Auties00/Cobalt.git</developerConnection>
    </scm>

    <distributionManagement>
        <snapshotRepository>
            <id>ossrh</id>
            <url>https://s01.oss.sonatype.org/content/repositories/snapshots</url>
        </snapshotRepository>
        <repository>
            <id>ossrh</id>
            <url>https://s01.oss.sonatype.org/service/local/staging/deploy/maven2/</url>
        </repository>
    </distributionManagement>

    <repositories>
        <repository>
            <id>jitpack.io</id>
            <name>Jitpack</name>
            <url>https://jitpack.io</url>
        </repository>
    </repositories>

    <properties>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <java.version>25</java.version>
        <maven.surefire.plugin.version>3.0.0-M9</maven.surefire.plugin.version>
        <maven.gpg.plugin.version>3.0.1</maven.gpg.plugin.version>
        <maven.compiler.plugin.version>3.15.0</maven.compiler.plugin.version>
        <maven.source.plugin.version>3.2.1</maven.source.plugin.version>
        <maven.javadoc.plugin.version>3.5.0</maven.javadoc.plugin.version>
        <maven.staging.plugin.version>0.8.0</maven.staging.plugin.version>
        <zxing.version>3.5.1</zxing.version>
        <json.version>2.0.57</json.version>
        <protoc.version>3.4.5</protoc.version>
        <junit.version>5.10.0-M1</junit.version>
        <libsignal.version>0.0.5</libsignal.version>
        <curve25519.version>3.0.1</curve25519.version>
        <linkpreview.version>2.3</linkpreview.version>
        <vcard.version>0.12.1</vcard.version>
        <qr.terminal.version>2.2</qr.terminal.version>
        <libphonenumber.version>9.0.4</libphonenumber.version>
        <maven.versions.version>2.15.0</maven.versions.version>
        <sl4j.version>2.0.13</sl4j.version>
        <apk.parser.version>2.6.10</apk.parser.version>
        <collections.version>1.0.0</collections.version>
        <javapoet.version>0.6.0</javapoet.version>
        <jmh.version>1.37</jmh.version>
        <selenium.version>4.27.0</selenium.version>
        <bouncycastle.version>1.80</bouncycastle.version>
        <pdfbox.version>3.0.5</pdfbox.version>
        <h2.mvstore.version>2.3.232</h2.mvstore.version>
    </properties>

    <profiles>
        <!--
            Javadoc reference linter. Opt-in, never bound to a normal build.
            Runs the standard doclet with the doclint "reference" group only,
            so it fails the build when a {@link}, {@linkplain}, {@value},
            @see, @param, @throws, or @exception in any doc comment points at
            a program element that does not resolve (wrong class, renamed
            method, bad signature, stale parameter name). It does NOT enforce
            presence of comments (the "missing" group, deliberately left off).

            Uses source level 25 plus enable-preview (NOT the release flag,
            which is incompatible with enable-preview) and pulls in the
            incubator vector module so preview/incubator sources parse.
            show=private so references inside private-member javadoc are
            checked too. See the additionalOptions below for the exact flags.

            The target module MUST compile for the result to be accurate.
            javadoc resolves intra-module references through the live source
            roots, which only include the generated Builder sources after the
            annotation processor has run during compile. Running
            javadoc-no-fork without a successful compile reports false
            "reference not found" for classes that genuinely exist, so always
            run compile in the same invocation and fix any compile break first.

            Usage:
                whole project
                    mvn -Pjavadoc-check -fae compile javadoc:javadoc-no-fork -DskipTests
                    (-fae reports every module; a module that depends on a
                     failed module is skipped, so fix upstream modules first.)

                one module in isolation (not blocked by other modules' refs)
                    mvn -DskipTests -pl modules/lib -am install
                    mvn -Pjavadoc-check -pl modules/lib compile javadoc:javadoc-no-fork -DskipTests

                narrow to a package   add -Dsubpackages=com.github.auties00.cobalt.stanza
                exclude packages      add -DexcludePackageNames=com.github.auties00.cobalt.call.*
        -->
        <profile>
            <id>javadoc-check</id>
            <build>
                <plugins>
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-javadoc-plugin</artifactId>
                        <version>3.11.2</version>
                        <configuration>
                            <source>${java.version}</source>
                            <show>private</show>
                            <doclint>reference</doclint>
                            <failOnError>true</failOnError>
                            <failOnWarnings>false</failOnWarnings>
                            <quiet>true</quiet>
                            <detectLinks>false</detectLinks>
                            <detectJavaApiLink>false</detectJavaApiLink>
                            <detectOfflineLinks>false</detectOfflineLinks>
                            <additionalOptions>
                                <additionalOption>--add-modules jdk.incubator.vector</additionalOption>
                                <additionalOption>-Xmaxerrs 100000</additionalOption>
                                <additionalOption>-Xmaxwarns 100000</additionalOption>
                            </additionalOptions>
                            <!--
                                Register the three JDK-standard custom tags so the
                                doclet does not emit "unknown tag" warnings; the
                                reference group does not need them, but it keeps the
                                log free of noise unrelated to broken references.
                            -->
                            <tags>
                                <tag>
                                    <name>apiNote</name>
                                    <placement>a</placement>
                                    <head>API Note:</head>
                                </tag>
                                <tag>
                                    <name>implSpec</name>
                                    <placement>a</placement>
                                    <head>Implementation Requirements:</head>
                                </tag>
                                <tag>
                                    <name>implNote</name>
                                    <placement>a</placement>
                                    <head>Implementation Note:</head>
                                </tag>
                            </tags>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>

        <profile>
            <id>sign</id>
            <activation>
                <property>
                    <name>performRelease</name>
                    <value>true</value>
                </property>
            </activation>
            <build>
                <plugins>
                    <!-- Attach the sourcecode -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-source-plugin</artifactId>
                        <version>${maven.source.plugin.version}</version>
                        <executions>
                            <execution>
                                <id>attach-sources</id>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- Generate and attach javadocs from source -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-javadoc-plugin</artifactId>
                        <version>${maven.javadoc.plugin.version}</version>
                        <executions>
                            <execution>
                                <id>attach-javadocs</id>
                                <goals>
                                    <goal>jar</goal>
                                </goals>
                            </execution>
                        </executions>
                        <configuration>
                            <release>${java.version}</release>
                            <failOnError>true</failOnError>
                            <show>private</show>
                            <debug>true</debug>
                            <verbose>true</verbose>
                        </configuration>
                    </plugin>

                    <!-- Sign the artifacts -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-gpg-plugin</artifactId>
                        <version>${maven.gpg.plugin.version}</version>
                        <executions>
                            <execution>
                                <id>sign-artifacts</id>
                                <phase>verify</phase>
                                <goals>
                                    <goal>sign</goal>
                                </goals>
                                <configuration>
                                    <keyname>${gpg.keyname}</keyname>
                                    <passphraseServerId>${gpg.passphrase}</passphraseServerId>
                                    <gpgArguments>
                                        <arg>--pinentry-mode</arg>
                                        <arg>loopback</arg>
                                    </gpgArguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- Deploy the artifact -->
                    <plugin>
                        <groupId>org.sonatype.central</groupId>
                        <artifactId>central-publishing-maven-plugin</artifactId>
                        <version>${maven.staging.plugin.version}</version>
                        <extensions>true</extensions>
                        <configuration>
                            <publishingServerId>central</publishingServerId>
                            <autoPublish>true</autoPublish>
                            <waitUntil>published</waitUntil>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
