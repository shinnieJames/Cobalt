# MCP transport
# Options: stdio, http
MCP_TRANSPORT=http

# Target platform(s) for snapshot extraction on startup.
# Options: auto, web, desktop_windows, desktop_macos, ios
# auto (default): always includes web, plus desktop_windows on Windows or desktop_macos on macOS.
#   If the desktop platform fails to extract, it is skipped and web remains available.
# desktop_macos and ios both use the native Mach-O + Ghidra pipeline.
# Any other value bootstraps that single platform only.
WEB_MCP_PLATFORM=auto

# Startup mode.
#   (empty): live extraction: connects to the target and extracts a fresh snapshot
#   cached: offline: loads the most recent local snapshot (no network needed)
WEB_MCP_MODE=

# Load a specific snapshot by ID instead of extracting or using the latest.
WEB_MCP_SNAPSHOT_ID=

# Ingest modules from a local directory of JS files instead of a live source.
WEB_MCP_SOURCE_DIR=

# Override the revision string when ingesting from a directory.
WEB_MCP_REVISION=

# Path to a decrypted IPA or Mach-O binary (required for iOS platform).
WEB_MCP_IOS_BINARY=

# Path to the WhatsApp macOS Catalyst app. Accepts the .app bundle or its
# Mach-O executable. Defaults to /Applications/WhatsApp.app if present.
WEB_MCP_MACOS_BINARY=

# Ghidra installation directory. Auto-detected if not set.
GHIDRA_INSTALL_DIR=

# Per-file Ghidra timeout in seconds for the native Mach-O pipeline (iOS + desktop_macos).
# Default: 1800.
WEB_MCP_NATIVE_ANALYSIS_TIMEOUT=

# Max CPU cores for Ghidra analysis on the native Mach-O pipeline. Default: 4.
WEB_MCP_NATIVE_MAX_CPU=

# Default locale for WhatsApp Web (affects UI language and selectors).
WEB_MCP_WEB_LOCALE=en-US

# Log level. Options: debug, info, warn, error, silent
# Logs go to stderr (stdout is reserved for MCP stdio transport).
WEB_MCP_LOG_LEVEL=info

# Android SDK root. Required for web_live_emulator_* tools. If unset, both
# ANDROID_HOME and ANDROID_SDK_ROOT are probed (in that order).
ANDROID_HOME=

# SMS verification provider used by web_live_emulator_register_whatsapp when
# a phone number is not supplied. Default: textverified.
WEB_MCP_SMS_PROVIDER=textverified

# textverified.com credentials (required when SMS provider is textverified).
TEXTVERIFIED_API_KEY=
TEXTVERIFIED_API_USERNAME=
